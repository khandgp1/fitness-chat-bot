# --- Storage ---
# SQLite database file. The dev clock sidecar lives next to it (<DB_PATH>.clock.json).
DB_PATH=data/v2.sqlite
# Client narratives: private directory OUTSIDE this repo, with its own git history (D16).
NARRATIVES_DIR=../fitness-bot-narratives
# Prompt files + autonomy.yaml (knowledge plane).
PROMPTS_DIR=prompts

# --- Pipeline tuning (Phase 4 config surface) ---
DEBOUNCE_MINUTES=3
CONTEXT_MAX_MESSAGES=30
CONTEXT_MAX_DAYS=14
STALENESS_THRESHOLD_EXCHANGES=5
STALENESS_THRESHOLD_DAYS=14
MAX_COACH_TURNS=6

# --- Server ---
PORT=3000

# --- Mode ---
# DEV_MODE=true enables clock mutation (advance/reset) and dev endpoints.
# MUST be false in any deployment serving real clients.
DEV_MODE=true

# --- Secrets (validated by the module that needs them, at its startup) ---
# ANTHROPIC_API_KEY=            # required from Stage 4 (agents)
# TELEGRAM_TOKEN=               # required from Stage 3 (telegram adapter)
# ADMIN_TOKEN=                  # required from Stage 6 (admin UI auth)
