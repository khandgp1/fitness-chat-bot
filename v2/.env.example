DB_PATH=data/v2.sqlite
# Narratives live OUTSIDE the repo (private client data, own git history)
NARRATIVES_DIR=../fitness-bot-narratives
PROMPTS_DIR=prompts

DEBOUNCE_MINUTES=3
CONTEXT_MAX_MESSAGES=30
CONTEXT_MAX_DAYS=14
STALENESS_THRESHOLD_EXCHANGES=5
STALENESS_THRESHOLD_DAYS=14
MAX_COACH_TURNS=6
DEFAULT_TIMEZONE=America/New_York
PORT=3000

# MUST be false in any deployment serving real clients
DEV_MODE=true

# LLM models
# ROUTER_MODEL=claude-haiku-4-5
# CLASSIFIER_MODEL=claude-haiku-4-5
# COACH_MODEL=claude-sonnet-5

# Secrets — each validated by the module that needs it
# TELEGRAM_TOKEN=      (Stage 3+)
# ANTHROPIC_API_KEY=   (Stage 4+)
# ADMIN_TOKEN=         (Stage 6+)
