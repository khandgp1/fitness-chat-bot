# Telegram (leave as placeholder_telegram_bot_token to run in sandbox-only mode)
TELEGRAM_BOT_TOKEN=placeholder_telegram_bot_token

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# Sandbox Integration
SANDBOX_REPLY_URL=http://localhost:3001/incoming-reply
BOT_PORT=4000

# Set to your Telegram numeric user ID for scheduler ticks, or "sandbox-user" for sandbox-only mode
BOT_CLIENT_ID=your_client_id_here

